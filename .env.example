---

# Justfile (alternative to Makefile using 'just' command runner)
# Install just: cargo install just OR brew install just

# Show available commands
default:
    @just --list

# Setup the project (run once after cloning)
setup:
    poetry install --with dev,test,docs
    poetry run pre-commit install
    poetry run setup-project
    @echo "✅ Project setup complete!"

# Install dependencies
install:
    poetry install --only=main

# Install all dependencies including dev
install-dev:
    poetry install --with dev,test,docs

# Run the application
run:
    poetry run python main.py

# Run in development mode with auto-reload
dev:
    poetry run uvicorn main:app --reload --host 0.0.0.0 --port 8000

# Run as CLI
cli *args:
    poetry run stock-cli {{args}}

# Format code
format:
    poetry run black .
    poetry run isort .

# Lint code
lint:
    poetry run black --check .
    poetry run isort --check-only .
    poetry run ruff check .
    poetry run mypy .

# Run tests
test:
    poetry run pytest

# Run tests with coverage
test-cov:
    poetry run pytest --cov=modules --cov=api --cov-report=html --cov-report=term

# Run specific test
test-single file:
    poetry run pytest {{file}} -v

# Run benchmarks
benchmark:
    poetry run pytest tests/ -m benchmark --benchmark-only

# Clean cache and build artifacts
clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name "*.pyc" -delete 2>/dev/null || true
    find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
    rm -rf build/ dist/ .coverage htmlcov/ .pytest_cache/ .mypy_cache/ .ruff_cache/

# Update dependencies
update:
    poetry update
    poetry show --outdated

# Build the package
build:
    poetry build

# Check project health
check:
    poetry check
    poetry run safety check
    poetry run bandit -r modules/ api/

# Run pre-commit hooks on all files
pre-commit:
    poetry run pre-commit run --all-files

# Serve documentation
docs:
    poetry run mkdocs serve

# Build documentation
docs-build:
    poetry run mkdocs build

# Docker commands
docker-build:
    docker build -t nse-stock-prediction .

docker-run:
    docker run -p 8000:8000 nse-stock-prediction

docker-compose-up:
    docker-compose up -d

docker-compose-down:
    docker-compose down

# Train models for popular stocks
train-popular:
    poetry run train-models train-all --model-type random_forest --save-models

# Analyze a stock
analyze symbol:
    poetry run stock-cli analyze {{symbol}}

# Show market status
market:
    poetry run stock-cli market-status

# Export requirements.txt for legacy systems
export-requirements:
    poetry export -f requirements.txt --output requirements.txt --without-hashes

# Run all checks before commit
pre-push: format lint test
    @echo "✅ All checks passed!"

---

# config.py
"""
Configuration management using Pydantic Settings
"""

import os
from pathlib import Path
from typing import List, Optional

from pydantic import Field
from pydantic_settings import BaseSettings


class Settings(BaseSettings):
    """Application settings with environment variable support."""

    # Application
    app_name: str = Field(default="NSE Stock Prediction API", env="APP_NAME")
    app_version: str = Field(default="1.0.0", env="APP_VERSION")
    environment: str = Field(default="development", env="ENVIRONMENT")
    debug: bool = Field(default=False, env="DEBUG")

    # API Configuration
    api_host: str = Field(default="0.0.0.0", env="API_HOST")
    api_port: int = Field(default=8000, env="API_PORT")
    api_workers: int = Field(default=1, env="API_WORKERS")
    api_reload: bool = Field(default=True, env="API_RELOAD")
    api_docs_url: str = Field(default="/docs", env="API_DOCS_URL")
    api_redoc_url: str = Field(default="/redoc", env="API_REDOC_URL")

    # Security
    secret_key: str = Field(default="dev-secret-key-change-in-production", env="SECRET_KEY")
    allowed_hosts: List[str] = Field(default=["localhost", "127.0.0.1"], env="ALLOWED_HOSTS")
    cors_origins: List[str] = Field(
        default=["http://localhost:3000", "http://localhost:8080"],
        env="CORS_ORIGINS"
    )

    # Database (Optional)
    database_url: str = Field(default="sqlite:///./stock_data.db", env="DATABASE_URL")

    # Redis (Optional)
    redis_url: str = Field(default="redis://localhost:6379/0", env="REDIS_URL")
    cache_ttl: int = Field(default=300, env="CACHE_TTL")  # 5 minutes

    # Model Configuration
    default_model_type: str = Field(default="random_forest", env="DEFAULT_MODEL_TYPE")
    model_save_path: Path = Field(default=Path("./models/saved_models"), env="MODEL_SAVE_PATH")
    prediction_cache_ttl: int = Field(default=60, env="PREDICTION_CACHE_TTL")
    batch_size: int = Field(default=32, env="BATCH_SIZE")
    max_workers: int = Field(default=4, env="MAX_WORKERS")

    # Data Configuration
    data_cache_path: Path = Field(default=Path("./data/cache"), env="DATA_CACHE_PATH")
    data_fetch_timeout: int = Field(default=30, env="DATA_FETCH_TIMEOUT")
    yahoo_finance_delay: float = Field(default=1.0, env="YAHOO_FINANCE_DELAY")
    max_retries: int = Field(default=3, env="MAX_RETRIES")

    # External APIs (Optional)
    alpha_vantage_api_key: Optional[str] = Field(default=None, env="ALPHA_VANTAGE_API_KEY")
    polygon_api_key: Optional[str] = Field(default=None, env="POLYGON_API_KEY")
    finnhub_api_key: Optional[str] = Field(default=None, env="FINNHUB_API_KEY")

    # Logging
    log_level: str = Field(default="INFO", env="LOG_LEVEL")
    log_file_path: Path = Field(default=Path("./logs/app.log"), env="LOG_FILE_PATH")
    log_max_size: str = Field(default="10MB", env="LOG_MAX_SIZE")
    log_backup_count: int = Field(default=5, env="LOG_BACKUP_COUNT")

    # Rate Limiting
    rate_limit_requests: int = Field(default=100, env="RATE_LIMIT_REQUESTS")
    rate_limit_period: int = Field(default=60, env="RATE_LIMIT_PERIOD")  # seconds

    # ML Model Settings
    feature_importance_threshold: float = Field(default=0.01, env="FEATURE_IMPORTANCE_THRESHOLD")
    cross_validation_folds: int = Field(default=5, env="CROSS_VALIDATION_FOLDS")
    hyperparameter_tuning: bool = Field(default=False, env="HYPERPARAMETER_TUNING")
    auto_retrain: bool = Field(default=False, env="AUTO_RETRAIN")
    retrain_interval: str = Field(default="24h", env="RETRAIN_INTERVAL")

    # Stock Market Settings
    market_timezone: str = Field(default="Asia/Kolkata", env="MARKET_TIMEZONE")
    trading_hours_start: str = Field(default="09:15", env="TRADING_HOURS_START")
    trading_hours_end: str = Field(default="15:30", env="TRADING_HOURS_END")
    weekend_trading: bool = Field(default=False, env="WEEKEND_TRADING")

    # Notification Settings (Optional)
    slack_webhook_url: Optional[str] = Field(default=None, env="SLACK_WEBHOOK_URL")
    discord_webhook_url: Optional[str] = Field(default=None, env="DISCORD_WEBHOOK_URL")
    email_smtp_server: Optional[str] = Field(default=None, env="EMAIL_SMTP_SERVER")
    email_smtp_port: int = Field(default=587, env="EMAIL_SMTP_PORT")
    email_username: Optional[str] = Field(default=None, env="EMAIL_USERNAME")
    email_password: Optional[str] = Field(default=None, env="EMAIL_PASSWORD")

    class Config:
        env_file = ".env"
        env_file_encoding = "utf-8"
        case_sensitive = False

    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        # Create directories if they don't exist
        self.model_save_path.mkdir(parents=True, exist_ok=True)
        self.data_cache_path.mkdir(parents=True, exist_ok=True)
        self.log_file_path.parent.mkdir(parents=True, exist_ok=True)


# Global settings instance
settings = Settings()

---

# mkdocs.yml (Documentation configuration)
site_name: NSE Stock Prediction Pipeline
site_description: Advanced stock analysis and prediction for NSE stocks
site_author: Your Name
site_url: https://your-username.github.io/nse-stock-prediction

repo_name: your-username/nse-stock-prediction
repo_url: https://github.com/your-username/nse-stock-prediction

theme:
  name: material
  palette:
    - scheme: default
      primary: blue
      accent: blue
      toggle:
        icon: material/brightness-7
        name: Switch to dark mode
    - scheme: slate
      primary: blue
      accent: blue
      toggle:
        icon: material/brightness-4
        name: Switch to light mode
  features:
    - navigation.tabs
    - navigation.sections
    - navigation.expand
    - navigation.indexes
    - toc.integrate
    - search.highlight
    - search.share

plugins:
  - search
  - mkdocstrings:
      handlers:
        python:
          selection:
            new_path_syntax: yes
  - mkdocs-jupyter

nav:
  - Home: index.md
  - User Guide:
      - Installation: user-guide/installation.md
      - Quick Start: user-guide/quick-start.md
      - API Usage: user-guide/api-usage.md
      - CLI Usage: user-guide/cli-usage.md
  - API Reference:
      - Stock Analyzer: api-reference/stock-analyzer.md
      - Technical Indicators: api-reference/technical-indicators.md
      - Prediction Models: api-reference/prediction-models.md
  - Examples:
      - Basic Analysis: examples/basic-analysis.md
      - Advanced Usage: examples/advanced-usage.md
      - Jupyter Notebooks: examples/notebooks.md
  - Development:
      - Contributing: development/contributing.md
      - Testing: development/testing.md
      - Deployment: development/deployment.md

markdown_extensions:
  - admonition
  - codehilite
  - pymdownx.superfences
  - pymdownx.tabbed
  - pymdownx.details
  - toc:
      permalink: true

---

# Poetry Commands Cheat Sheet (COMMANDS.md)

# Poetry Commands for NSE Stock Prediction Pipeline

## Basic Poetry Commands

### Project Management
```bash
# Initialize new project
poetry new nse-stock-prediction

# Initialize in existing directory
poetry init

# Show project information
poetry show --tree

# Check project configuration
poetry check
```

### Dependency Management
```bash
# Install all dependencies
poetry install

# Install only main dependencies
poetry install --only=main

# Install with specific groups
poetry install --with dev,test,docs

# Add new dependency
poetry add pandas numpy

# Add development dependency
poetry add --group dev pytest black

# Add optional dependency
poetry add --optional redis

# Remove dependency
poetry remove package-name

# Update dependencies
poetry update

# Update specific package
poetry update pandas

# Show outdated packages
poetry show --outdated
```

### Virtual Environment
```bash
# Show virtual environment info
poetry env info

# Activate shell
poetry shell

# Run command in virtual environment
poetry run python script.py
poetry run pytest

# Exit shell
exit

# Remove virtual environment
poetry env remove python
```

### Building and Publishing
```bash
# Build package
poetry build

# Publish to PyPI
poetry publish

# Build and publish
poetry publish --build

# Publish to test PyPI
poetry publish --repository testpypi
```

## Project-Specific Commands

### Setup and Installation
```bash
# Complete project setup
poetry install --with dev,test,docs
poetry run pre-commit install
poetry run setup-project

# Quick development setup
make setup  # or just setup

# Install production only
poetry install --only=main
```

### Running the Application
```bash
# Run as API server
poetry run python main.py api
poetry run stock-api

# Run as CLI
poetry run python main.py
poetry run stock-cli --help

# Development mode
poetry run uvicorn main:app --reload
make dev  # or just dev
```

### CLI Commands
```bash
# Analyze a stock
poetry run stock-cli analyze TCS
poetry run stock-cli analyze RELIANCE --period 2y --model-type gradient_boost

# Get prediction only
poetry run stock-cli predict INFY

# Technical analysis
poetry run stock-cli technical HDFC --period 6mo

# Stock information
poetry run stock-cli info TATAMOTORS

# Compare stocks
poetry run stock-cli compare TCS INFY WIPRO

# Market status
poetry run stock-cli market-status

# Manage watchlist
poetry run stock-cli watchlist add TCS
poetry run stock-cli watchlist list
poetry run stock-cli watchlist analyze
```

### Model Training
```bash
# Train single stock
poetry run train-models train-single TCS
poetry run train-models train-single RELIANCE --model-type gradient_boost

# Train multiple stocks
poetry run train-models train-all --stocks TCS INFY RELIANCE
poetry run train-models train-all --sector IT
poetry run train-models train-all --model-type random_forest

# Compare models
poetry run train-models compare-models TCS --models random_forest gradient_boost
```

### Development Commands
```bash
# Format code
poetry run black .
poetry run isort .
make format  # or just format

# Lint code
poetry run ruff check .
poetry run mypy .
make lint  # or just lint

# Run tests
poetry run pytest
poetry run pytest --cov=modules --cov=api
make test  # or just test

# Run specific test
poetry run pytest tests/test_stock_analyzer.py -v

# Run benchmarks
poetry run pytest tests/ -m benchmark --benchmark-only
```

### Project Maintenance
```bash
# Clean cache and artifacts
find . -name __pycache__ -exec rm -rf {} +
rm -rf .pytest_cache .mypy_cache .ruff_cache
make clean  # or just clean

# Update dependencies and check security
poetry update
poetry run safety check
poetry run bandit -r modules/ api/
make check  # or just check

# Export requirements.txt (for legacy systems)
poetry export -f requirements.txt --output requirements.txt
make export-requirements
```

### Documentation
```bash
# Serve documentation locally
poetry run mkdocs serve
make docs  # or just docs

# Build documentation
poetry run mkdocs build
make docs-build
```

### Docker Commands
```bash
# Build Docker image
docker build -t nse-stock-prediction .
make docker-build  # or just docker-build

# Run Docker container
docker run -p 8000:8000 nse-stock-prediction
make docker-run  # or just docker-run

# Docker Compose
docker-compose up -d
make docker-compose-up
```

## Troubleshooting

### Common Issues and Solutions

#### Poetry Installation Issues
```bash
# Clear cache
poetry cache clear pypi --all

# Reinstall Poetry
curl -sSL https://install.python-poetry.org | python3 -

# Update Poetry
poetry self update
```

#### Virtual Environment Issues
```bash
# Remove and recreate virtual environment
poetry env remove python
poetry install

# Use specific Python version
poetry env use python3.11
poetry install
```

#### Dependency Conflicts
```bash
# Show dependency tree
poetry show --tree

# Lock without updating
poetry lock --no-update

# Update lock file
poetry lock

# Force update
poetry update --lock
```

#### Import Issues
```bash
# Verify installation
poetry run python -c "import modules.stock_analyzer; print('OK')"

# Check Python path
poetry run python -c "import sys; print(sys.path)"

# Install in development mode
poetry install --editable .
```

### Performance Tips

#### Speed Up Installation
```bash
# Use parallel installation
poetry config installer.parallel true

# Skip virtual environment creation (use system Python)
poetry config virtualenvs.create false

# Use in-project virtual environment
poetry config virtualenvs.in-project true
```

#### Caching
```bash
# Show cache info
poetry cache info

# Clear specific cache
poetry cache clear pypi package-name

# Clear all cache
poetry cache clear pypi --all
```

This comprehensive command reference should help you effectively use Poetry with the NSE Stock Prediction Pipeline. The combination of Poetry's dependency management with the project's custom scripts provides a powerful development experience.
